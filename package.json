{
  "name": "@blankparticle/www",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "wrangler types",
    "dev": "vite dev --host",
    "build": "vite build",
    "preview": "pnpm run build && wrangler dev",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "deploy": "pnpm run build && wrangler deploy",
    "format": "prettier --write .",
    "lint": "prettier --check . && oxlint"
  },
  "devDependencies": {
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/source-sans-3": "^5.2.9",
    "@fontsource/stix-two-text": "^5.2.8",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.59.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "4.2.4",
    "@takumi-rs/image-response": "^1.1.2",
    "@types/node": "^25.6.0",
    "eslint-plugin-svelte": "^3.17.1",
    "oxlint": "^1.62.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prettier-plugin-tailwindcss-canonical-classes": "^0.1.4",
    "react": "^19.2.5",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "tailwindcss": "4.2.4",
    "tailwindcss-spring": "^1.0.1",
    "vite": "8.0.10",
    "wrangler": "^4.87.0"
  },
  "packageManager": "pnpm@10.32.1"
}
